<?xml version="1.0" encoding="UTF-8"?>
<profiles version="12">
	<profile name="CustomJavaStyle" version="12">
		<!-- Blank line before closing bracket rule -->
		<setting id="org.eclipse.jdt.core.formatter.blank_lines_before_closing_brace_in_block" value="1"/>
		<setting id="org.eclipse.jdt.core.formatter.blank_lines_before_closing_brace_in_array_initializer" value="1"/>
		<!-- To prevent the Spotless Java Eclipse formatter from combining manually broken lines -->
		<setting id="org.eclipse.jdt.core.formatter.join_wrapped_lines" value="false"/>
		<!-- ! -->
		<!--setting id="org.eclipse.jdt.core.formatter.blank_lines_between_method_declarations" value="3"/-->
		<!-- One blank line before class body closure brace  -->
		<setting id="org.eclipse.jdt.core.formatter.blank_lines_after_last_class_body_declaration" value="1"/>
		<!-- Controls the number of blank lines inserted between method declarations -->
		<setting id="org.eclipse.jdt.core.formatter.blank_lines_before_method" value="1"/>
		<!-- Keeps existing blank lines up to this limit (prevents collapsing them) -->
		<setting id="org.eclipse.jdt.core.formatter.number_of_empty_lines_to_preserve" value="2"/>
	</profile>
</profiles>